---
import Base from '../layouts/Base.astro';
---

<Base title="About — Clear" description="About this site.">
  <section class="mx-auto max-w-3xl px-[var(--space-sm)] py-[var(--space-2xl)]">
    <h1 class="text-4xl">About</h1>
    <p class="mt-[var(--space-md)] text-lg text-muted">
      Replace this copy with the story behind your brand. The Clear template keeps the
      structure out of your way so you can focus on the words.
    </p>
    <p class="mt-[var(--space-sm)]">
      Edit this page at <code class="rounded bg-surface px-1 py-0.5 text-sm">src/pages/about.astro</code>.
    </p>
  </section>
</Base>
