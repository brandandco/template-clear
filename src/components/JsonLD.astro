---
// Builds default WebSite + Organization + WebPage schema
// from site config. Extensible with additional schemas per page.
import { siteConfig } from '../site.config.mjs';

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';

interface Props {
  page: {
    title: string;
    description: string;
    path: string;
  };
  extra?: object[];
}

const { page, extra = [] } = Astro.props;
const url = `${site}${page.path}`;

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteConfig.name,
  "url": site,
  "description": siteConfig.description,
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": siteConfig.name,
  "url": site,
  "logo": `${site}/favicon.svg`,
  "contactPoint": {
    "@type": "ContactPoint",
    "email": siteConfig.email,
    "contactType": "customer service"
  }
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": page.title,
  "description": page.description,
  "url": url,
  "isPartOf": { "@id": site }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": site
    },
    ...(page.path !== '/' ? [{
      "@type": "ListItem",
      "position": 2,
      "name": page.title,
      "item": url
    }] : [])
  ]
};

const allSchemas = [
  websiteSchema,
  organizationSchema,
  webPageSchema,
  breadcrumbSchema,
  ...extra
];
---
<script
  type="application/ld+json"
  set:html={JSON.stringify(allSchemas)}
/>
