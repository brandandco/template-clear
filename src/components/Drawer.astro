---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<div id="drawer-overlay" class="drawer-overlay" aria-hidden="true"></div>

<aside id="drawer" class="drawer" inert aria-label="Site menu">
  <div class="flex items-center justify-between">
    <span class="text-xs font-bold uppercase tracking-widest text-muted">Menu</span>
    <button
      type="button"
      data-drawer-close
      aria-label="Close menu"
      class="inline-flex h-10 w-10 items-center justify-center justify-self-end transition-colors hover:text-accent"
    >
      <svg width="17" height="17" viewBox="0 0 17.16 17.16" fill="currentColor" aria-hidden="true">
        <path d="M.28,1.61C.09,1.43,0,1.2,0,.95c0-.26.1-.48.28-.67s.41-.28.66-.28.48.09.66.28l15.27,15.27c.19.19.28.41.28.66,0,.26-.09.48-.28.66s-.41.28-.67.28-.48-.09-.67-.28L.28,1.61ZM1.61,16.88c-.19.19-.41.28-.66.28-.26,0-.48-.09-.66-.28S0,16.47,0,16.21c0-.26.09-.48.28-.66L15.55.28C15.74.09,15.96,0,16.21,0s.48.09.66.28.28.41.28.66-.09.48-.28.66L1.61,16.88Z"/>
      </svg>
    </button>
  </div>

  <nav class="mt-[var(--space-lg)]" aria-label="Drawer">
    <ul class="flex flex-col gap-[var(--space-sm)]">
      {links.map((l) => (
        <li>
          <a href={l.href} class="text-3xl font-extrabold transition-colors hover:text-accent">
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="mt-auto pt-[var(--space-lg)]">
    <button
      type="button"
      data-theme-toggle
      class="inline-flex items-center gap-[var(--space-2xs)] rounded-md border border-border px-[var(--space-sm)] py-[var(--space-2xs)] text-sm font-semibold transition-colors hover:bg-bg"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
      </svg>
      <span>Toggle theme</span>
    </button>
  </div>
</aside>
