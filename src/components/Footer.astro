---
const year = new Date().getFullYear();
---

<footer class="h-[14vh]">
  <div class="container grid h-full grid-cols-[1fr_auto_1fr] items-center">
    <p class="col-start-2 text-[10px] text-muted">Copyright &copy; 1999-{year}. All rights reserved.</p>

    <!-- Dark / light mode toggle -->
    <button
      type="button"
      data-theme-toggle
      aria-label="Toggle dark / light mode"
      class="col-start-3 inline-flex h-10 w-10 items-center justify-center justify-self-end transition-colors hover:text-accent"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <g fill="currentColor" fill-rule="nonzero">
          <path d="M12,22 C17.5228475,22 22,17.5228475 22,12 C22,6.4771525 17.5228475,2 12,2 C6.4771525,2 2,6.4771525 2,12 C2,17.5228475 6.4771525,22 12,22 Z M12,20.5 L12,3.5 C16.6944204,3.5 20.5,7.30557963 20.5,12 C20.5,16.6944204 16.6944204,20.5 12,20.5 Z"/>
        </g>
      </svg>
    </button>
  </div>
</footer>
