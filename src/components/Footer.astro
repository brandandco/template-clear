---
const year = new Date().getFullYear();
---

<footer class="border-t border-border">
  <div class="wrapper flex flex-col items-center justify-between gap-[var(--space-xs)] py-[var(--space-lg)] text-sm text-muted sm:flex-row">
    <p>&copy; {year} Clear. All rights reserved.</p>
    <button type="button" data-theme-toggle class="font-semibold transition-colors hover:text-accent">
      Toggle theme
    </button>
  </div>
</footer>
