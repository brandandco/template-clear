---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-30 h-[100px] min-h-[100px] bg-bg/80 backdrop-blur">
  <div class="container grid h-full grid-cols-[1fr_auto_1fr] items-center">
    <!-- Logo (left) -->
    <a href="/" class="justify-self-start text-xl font-extrabold tracking-tight">Clear</a>

    <!-- Primary nav (center) -->
    <nav class="hidden justify-self-center md:block" aria-label="Primary">
      <ul class="flex items-center gap-[var(--space-md)] text-sm font-semibold">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              aria-current={current === l.href ? 'page' : undefined}
              class:list={[
                'transition-colors hover:text-accent',
                { 'text-accent': current === l.href },
              ]}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Hamburger (right) — SF Symbol: text.menu, no border -->
    <button
      type="button"
      data-drawer-open
      aria-controls="drawer"
      aria-label="Open menu"
      class="inline-flex h-10 w-10 items-center justify-center justify-self-end transition-colors hover:text-accent"
    >
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="3.5" y1="7" x2="20.5" y2="7" />
        <line x1="3.5" y1="12" x2="20.5" y2="12" />
        <line x1="3.5" y1="17" x2="20.5" y2="17" />
      </svg>
    </button>
  </div>
</header>
