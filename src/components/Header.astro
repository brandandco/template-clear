---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-30 border-b border-border bg-bg/80 backdrop-blur">
  <div class="mx-auto grid max-w-6xl grid-cols-[1fr_auto_1fr] items-center px-[var(--space-sm)] py-[var(--space-xs)]">
    <!-- Logo (left) -->
    <a href="/" class="justify-self-start text-xl font-extrabold tracking-tight">Clear</a>

    <!-- Primary nav (center) -->
    <nav class="hidden justify-self-center md:block" aria-label="Primary">
      <ul class="flex items-center gap-[var(--space-md)] text-sm font-semibold">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              aria-current={current === l.href ? 'page' : undefined}
              class:list={[
                'transition-colors hover:text-accent',
                { 'text-accent': current === l.href },
              ]}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Hamburger (right) -->
    <button
      type="button"
      data-drawer-open
      aria-controls="drawer"
      aria-label="Open menu"
      class="inline-flex h-10 w-10 items-center justify-center justify-self-end rounded-md border border-border transition-colors hover:bg-surface"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>
</header>
