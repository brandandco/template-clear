---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-30 h-[100px] min-h-[100px] bg-bg/80 backdrop-blur">
  <div class="container grid h-full grid-cols-[1fr_auto_1fr] items-center">
    <!-- Logo (left) -->
    <a href="/" class="justify-self-start text-xl font-extrabold tracking-tight">Clear</a>

    <!-- Primary nav (center) -->
    <nav class="hidden justify-self-center md:block" aria-label="Primary">
      <ul class="flex items-center gap-[var(--space-md)] text-sm font-semibold">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              aria-current={current === l.href ? 'page' : undefined}
              class:list={[
                'transition-colors hover:text-accent',
                { 'text-accent': current === l.href },
              ]}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Hamburger (right) — SF Symbol: text.menu, no border -->
    <button
      type="button"
      data-drawer-open
      aria-controls="drawer"
      aria-label="Open menu"
      class="inline-flex h-10 w-10 items-center justify-center justify-self-end transition-colors hover:text-accent"
    >
      <svg width="26" height="21" viewBox="0 0 23.47 18.91" fill="currentColor" aria-hidden="true">
        <path d="M.94,1.89c-.26,0-.49-.09-.67-.28-.18-.18-.27-.41-.27-.67S.09.45.27.27s.4-.27.67-.27h21.59c.26,0,.49.09.67.27.18.18.27.4.27.67s-.09.49-.27.67-.4.28-.67.28H.94ZM.94,10.39c-.26,0-.49-.09-.67-.27-.18-.18-.27-.4-.27-.67s.09-.49.27-.67c.18-.18.4-.27.67-.27h21.59c.26,0,.49.09.67.27s.27.4.27.67-.09.49-.27.67-.4.27-.67.27H.94ZM.94,18.91c-.26,0-.49-.09-.67-.27-.18-.18-.27-.4-.27-.67s.09-.49.27-.67c.18-.18.4-.28.67-.28h15.01c.27,0,.5.09.68.28s.27.41.27.67-.09.49-.27.67-.41.27-.68.27H.94Z"/>
      </svg>
    </button>
  </div>
</header>
